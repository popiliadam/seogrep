DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# Live keyword-research switch. research_keywords hits the paid DataForSEO API ONLY when
# this is exactly "1" AND both DATAFORSEO_* are set; unset keeps live OFF (the tool returns
# a clear "not yet enabled" error and charges nothing). Dev-smoke spend is capped at
# $3/day by guardrails/dfs-budget.sh.
DFS_LIVE=
# Google OAuth (GSC) — adlar Netlify prod'la birebir doğrulandı (insan gözü, 2026-07-19)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TOKEN_ENCRYPTION_KEY=
RESEND_API_KEY=
RESEND_SEGMENT_ID=
# Verified sender for transactional mail (welcome email). Unset => welcome is skipped.
RESEND_FROM_EMAIL=
