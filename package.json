{
  "name": "pseo-saas",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": { "node": ">=22" },
  "scripts": {
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "build": "turbo run build",
    "verify": "bash guardrails/verify.sh",
    "waitlist:smoke": "node scripts/waitlist-smoke.mjs",
    "lighthouse": "pnpm --filter @pseo/web build && lhci autorun"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "eslint": "^9.20.0",
    "typescript-eslint": "^8.20.0"
  }
}
