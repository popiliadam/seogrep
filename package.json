{
  "name": "pseo-saas",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": { "node": ">=22" },
  "scripts": {
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "build": "turbo run build",
    "verify": "bash guardrails/verify.sh",
    "verify:db": "bash guardrails/verify-db.sh",
    "waitlist:smoke": "node scripts/waitlist-smoke.mjs",
    "email:smoke": "node scripts/email-smoke.mjs",
    "lighthouse": "pnpm --filter @pseo/web build && lhci autorun",
    "db:start": "supabase start --workdir packages/db",
    "db:reset": "supabase db reset --workdir packages/db",
    "db:types": "supabase gen types typescript --local --workdir packages/db > packages/db/src/types.ts"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "supabase": "^2.109.1",
    "turbo": "2.10.4",
    "typescript": "^5.7.0",
    "eslint": "^9.20.0",
    "typescript-eslint": "^8.20.0"
  }
}
